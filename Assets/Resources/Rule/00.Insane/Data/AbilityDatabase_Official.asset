    specialEffect: 0
  - name: "\uC5F0\uACA9"
    type: 1
    designatedSpecialtyType: 1
    designatedEntries:
    - isAreaEntry: 1
      value: "\uD3ED\uB825"
    effect: "\uB2F9\uC2E0\uC774 \uACF5\uACA9\uD588\uC744 \uB54C, \uACF5\uACA9 \uBAA9\uD45C\uAC00
      \uD68C\uD53C\uD310\uC815\uC5D0 \uC131\uACF5\uD588\uB2E4\uBA74 \uC0AC\uC6A9\uD560
      \uC218 \uC788\uB2E4. \uACF5\uACA9 \uBAA9\uD45C\uB294 \uC774 \uC5B4\uBE4C\uB9AC\uD2F0\uC758
      \uC9C0\uC815\uD2B9\uAE30\uB85C \uD55C \uBC88 \uB354 \uD68C\uD53C\uD310\uC815(\uD50C\uB86F\uCE58\uC640
      \uC0C1\uAD00\uC5C6\uC774 \uC5B4\uBE4C\uB9AC\uD2F0\uC758 \uC9C0\uC815\uD2B9\uAE30\uB85C
      \uD310\uC815)\uC744 \uD574\uC57C \uD55C\uB2E4. \uC774 \uD68C\uD53C\uD310\uC815\uC5D0
      \uC2E4\uD328\uD558\uBA74 \uACF5\uACA9\uC774 \uBA85\uC911\uD55C\uB2E4."
    library: "\uC778\uC138\uC778  1"
    acquireMode: 0
    maxAcquireCount: 1
    statEffect:
      lifeBonus: 0
      sanityBonus: 0
      specialtyBonus: 0
    acquireCondition: 
    specialEffect: 0
  - name: "\uCC29\uAC01"
    type: 1
    designatedSpecialtyType: 1
    designatedEntries:
    - isAreaEntry: 1
      value: "\uC815\uC11C"
    effect: "\uB2F9\uC2E0\uC774 \u3010\uAD11\uAE30\u3011\uB97C \uD68D\uB4DD\uD588\uC744
      \uB54C \uC0AC\uC6A9\uD560 \uC218 \uC788\uB2E4. \uC9C0\uC815\uD2B9\uAE30 \uD310\uC815\uC5D0
      \uC131\uACF5\uD558\uBA74 \uB2F9\uC2E0\uC774 \uAC00\uC9C0\uACE0 \uC788\uB294
      \u3010\uAD11\uAE30\u3011\uB97C \uC6D0\uD558\uB294 \uB9CC\uD07C \uC120\uD0DD\uD558\uC5EC
      \uB371\uC5D0 \uB418\uB3CC\uB9AC\uACE0, \uB2E4\uC2DC \uC11E\uB294\uB2E4. \uADF8\uB9AC\uACE0
      \uB418\uB3CC\uB9B0 \u3010\uAD11\uAE30\u3011\uC640 \uAC19\uC740 \uC218\uB9CC\uD07C
      \uC0C8\uB85C\uC6B4 \u3010\uAD11\uAE30\u3011\uB97C \uC5BB\uB294\uB2E4."
    library: "\uC778\uC138\uC778  1"
    acquireMode: 0
    maxAcquireCount: 1
    statEffect:
      lifeBonus: 0
      sanityBonus: 0
      specialtyBonus: 0
