    effect: "\uB2F9\uC2E0\uC774 \uD50C\uB7EC\uC2A4 \u3010\uAC10\uC815\u3011\uC744
      \uAC00\uC9C4 \uCE90\uB9AD\uD130\uAC00 \uB370\uBBF8\uC9C0\uB97C \uC785\uC5C8\uC744
