    specialEffect: 0
  - name: "\uC800\uACA9"
    type: 0
    designatedSpecialtyType: 2
    designatedEntries:
    - isAreaEntry: 1
      value: "\uAE30\uC220"
    - isAreaEntry: 0
      value: "\uC0AC\uACA9"
    effect: "\uBAB9 1\uAC1C\uCCB4\uB97C \uBAA9\uD45C\uB85C \uC120\uD0DD\uD558\uC5EC
      \uBA85\uC911\uD310\uC815\uC744 \uD55C\uB2E4. \uBA85\uC911\uD310\uC815\uC774
      \uC131\uACF5\uD558\uBA74 \uBAA9\uD45C\uC5D0\uAC8C 2d6\uC810\uC758 \uB370\uBBF8\uC9C0\uB97C
      \uC785\uD78C\uB2E4."
    library: "\uC778\uC138\uC778  1"
    acquireMode: 0
    maxAcquireCount: 1
    statEffect:
      lifeBonus: 0
      sanityBonus: 0
      specialtyBonus: 0
