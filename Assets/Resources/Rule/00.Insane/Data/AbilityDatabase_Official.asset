    effect: "\uB2F9\uC2E0\uC774 \uADF8 \uC138\uC158\uC5D0\uC11C \uCC98\uC74C \uBCF4\uB294
      \uAD34\uC774 \uC5D0\uB108\uBBF8\uC640 \uB9CC\uB0A0 \uB54C \uC0AC\uC6A9\uD560
