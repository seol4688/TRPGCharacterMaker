  - name: "\uD2B8\uB9AD"
    type: 0
    designatedSpecialtyType: 1
    designatedEntries:
    - isAreaEntry: 1
      value: "\uAE30\uC220"
    effect: "\uBAA9\uD45C 1\uBA85\uC744 \uC120\uD0DD\uD558\uC5EC \uBA85\uC911\uD310\uC815\uC744
      \uD55C\uB2E4. \uBA85\uC911\uD310\uC815\uC774 \uC131\uACF5\uD558\uACE0, \uBAA9\uD45C\uAC00
      \uD68C\uD53C\uD310\uC815\uC5D0 \uC2E4\uD328\uD558\uBA74 \uBAA9\uD45C\uC5D0\uAC8C
      2\uC810\uC758 \uB370\uBBF8\uC9C0\uB97C \uC785\uD78C\uB2E4. \uC774\uB54C \uBAA9\uD45C\uB294
      \uD68C\uD53C\uD310\uC815\uC5D0 -2\uC758 \uC218\uC815\uC744 \uC801\uC6A9\uD55C\uB2E4."
