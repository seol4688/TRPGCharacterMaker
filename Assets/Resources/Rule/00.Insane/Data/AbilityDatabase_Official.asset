    specialEffect: 0
  - name: "\uB09C\uB3D9"
    type: 0
    designatedSpecialtyType: 2
    designatedEntries:
    - isAreaEntry: 1
      value: "\uD3ED\uB825"
    - isAreaEntry: 0
      value: "\uBCD1\uAE30"
    effect: "\uB2F9\uC2E0\uC774 \uACF5\uAC1C\uD55C \u3010\uAD11\uAE30\u3011\uC758
      \uC218\uB9CC\uD07C \uBAA9\uD45C(\uC5D0\uB108\uBBF8\uC758 \uACBD\uC6B0 1D6\uBA85\uAE4C\uC9C0
      \uC120\uD0DD\uD55C\uB2E4)\uB97C \uC120\uD0DD\uD558\uC5EC \uBA85\uC911\uD310\uC815\uC744
      \uD55C\uB2E4. \uBA85\uC911\uD310\uC815\uC774 \uC131\uACF5\uD558\uBA74 \uBAA9\uD45C\uB294
      \uAC01\uC790 \uD68C\uD53C\uD310\uC815\uC744 \uD55C\uB2E4. \uD68C\uD53C\uD310\uC815\uC5D0
      \uC2E4\uD328\uD55C \uBAA9\uD45C\uC5D0\uAC8C 1D6-2\uC810\uC758 \uB300\uBBF8\uC9C0(\uCD5C\uC800
      0\uC810)\uB97C \uC785\uD78C\uB2E4."
    library: "\uC778\uC138\uC778  1"
    acquireMode: 0
    maxAcquireCount: 1
    statEffect:
      lifeBonus: 0
      sanityBonus: 0
      specialtyBonus: 0
    acquireCondition: 
    specialEffect: 0
  - name: "\uBD09\uC778"
    type: 0
    designatedSpecialtyType: 4
    designatedEntries: []
    effect: "\uC6D0\uD558\uB294 \uB9CC\uD07C \uBAA9\uD45C\uB97C \uC120\uD0DD\uD55C\uB2E4.
      \uAD34\uC774 \uBD84\uC57C\uC5D0\uC11C \uBB34\uC791\uC704\uB85C \uC9C0\uC815\uD2B9\uAE30\uB97C
      \uD558\uB098 \uC120\uD0DD\uD558\uC5EC \uBA85\uC911\uD310\uC815\uC744 \uD55C\uB2E4.
      \uBA85\uC911\uD310\uC815\uC5D0 \uC131\uACF5\uD558\uBA74 \uC774 \uC5B4\uBE4C\uB9AC\uD2F0\uB97C
      \uC0AC\uC6A9\uD55C \uC790\uC758 \uC774\uC131\uCE58\uAC00 1\uC810 \uAC10\uC18C\uD55C\uB2E4.
      \uBAA9\uD45C\uB294 \uAC01\uC790 \uD68C\uD53C\uD310\uC815\uC744 \uD574\uC11C
      \uC2E4\uD328\uD558\uBA74 \uADF8 \uB77C\uC6B4\uB4DC \uB3D9\uC548 \uACF5\uACA9\uACFC
      \uD68C\uD53C\uD310\uC815\uC744 \uD560 \uC218 \uC5C6\uB2E4."
    library: "\uC778\uC138\uC778  1"
    acquireMode: 0
    maxAcquireCount: 1
    statEffect:
      lifeBonus: 0
      sanityBonus: 0
      specialtyBonus: 0
    acquireCondition: 
    specialEffect: 0
  - name: "\uC18C\uD658"
    type: 0
    designatedSpecialtyType: 4
    designatedEntries: []
    effect: "\uBAA9\uD45C\uB97C 1\uBA85 \uC120\uD0DD\uD55C\uB2E4.\uAD34\uC774 \uBD84\uC57C\uC5D0\uC11C
      \uBB34\uC791\uC704\uB85C \uC9C0\uC815\uD2B9\uAE30\uB97C \uD558\uB098 \uC120\uD0DD\uD558\uC5EC
      \uBA85\uC911\uD310\uC815\uC744 \uD55C\uB2E4. \uBA85\uC911\uD310\uC815\uC5D0
      \uC131\uACF5\uD558\uBA74 \uC774 \uC5B4\uBE4C\uB9AC\uD2F0\uB97C \uC0AC\uC6A9\uD55C
      \uC790\uC758 \u3010\uC774\uC131\uCE58\u3011\uAC00 1\uC810 \uAC10\uC18C\uD55C\uB2E4.
      \uBAA9\uD45C\uB294 -3\uC758 \uC218\uC815\uC744 \uC801\uC6A9\uD558\uC5EC \uD68C\uD53C\uD310\uC815\uC744
      \uD55C\uB2E4. \uBAA9\uD45C\uAC00 \uD68C\uD53C\uD310\uC815\uC5D0 \uC2E4\uD328\uD558\uBA74
      \uBAA9\uD45C\uC5D0\uAC8C 2D6\uC810\uC758 \uB300\uBBF8\uC9C0\uB97C \uC785\uD78C\uB2E4."
    library: "\uC778\uC138\uC778  1"
    acquireMode: 0
    maxAcquireCount: 1
    statEffect:
      lifeBonus: 0
      sanityBonus: 0
      specialtyBonus: 0
