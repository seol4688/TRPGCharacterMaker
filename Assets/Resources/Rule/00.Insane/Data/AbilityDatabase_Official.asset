    effect: "\uB4DC\uB77C\uB9C8 \uC7A5\uBA74\uC5D0\uC11C \uC0AC\uC6A9\uD560 \uC218
      \uC788\uB2E4. \uB2F9\uC2E0\uC758 PC\uB294 \u3010\uC774\uC131\uCE58\u3011\uB97C
      1\uC810 \uC18C\uBE44\uD55C\uB2E4. \uB2F9\uC2E0\uC740 \uB208\uC744 \uAC10\uACE0
      \uAC80\uC9C0\uB97C \uCE90\uB9AD\uD130 \uC2DC\uD2B8\uC758 \uD2B9\uAE30 \uB9AC\uC2A4\uD2B8
      \uC911 \u300A\uB9C8\uC220\u300B \uC704\uC5D0 \uC62C\uB9B0\uB2E4. GM\uC740 \uC544\uBB34\uAC70\uB098
      \uD2B9\uAE30\uB97C \uD558\uB098 \uC120\uD0DD\uD574\uC11C \uC120\uC5B8\uD55C\uB2E4.
      \uB2F9\uC2E0\uC740 \uB208\uC744 \uAC10\uC740 \uCC44\uB85C \uC190\uAC00\uB77D\uC744
      \uC6C0\uC9C1\uC778\uB2E4. \uB208\uC744 \uB5B4\uC744 \uB54C, GM\uC774 \uC9C0\uC815\uD55C
      \uD2B9\uAE30 \uC704\uC5D0 \uC190\uAC00\uB77D\uC774 \uC62C\uB77C\uAC00 \uC788\uB2E4\uBA74
      \uC6D0\uD558\uB294 \u3010\uBE44\uBC00\u3011\uC744 \uD558\uB098 \uD68D\uB4DD\uD560
      \uC218 \uC788\uB2E4. \uADF8\uB807\uC9C0 \uC54A\uB2E4\uBA74 \uB2F9\uC2E0\uC758
