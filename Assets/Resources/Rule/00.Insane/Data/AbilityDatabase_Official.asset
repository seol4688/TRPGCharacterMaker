  - name: "\uC804\uC7A5\uC774\uB3D9"
    type: 1
    designatedSpecialtyType: 3
    designatedEntries: []
    effect: "\uC9C0\uC6D0\uD589\uB3D9. \uC774 \uC5B4\uBE4C\uB9AC\uD2F0\uB97C \uC0AC\uC6A9\uD558\uBA74
