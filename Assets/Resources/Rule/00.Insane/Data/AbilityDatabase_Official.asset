  - name: "\uAC15\uD0C0"
    type: 0
    designatedSpecialtyType: 1
    designatedEntries:
    - isAreaEntry: 1
      value: "\uD3ED\uB825"
    effect: "\uBAA9\uD45C 1\uBA85\uC744 \uC120\uD0DD\uD558\uC5EC \uBA85\uC911\uD310\uC815\uC744
      \uD55C\uB2E4. \uC774\uB54C \uC790\uC2E0\uC758 \uC18D\uB3C4 \uC218\uCE58\uB9CC\uD07C
      \uBA85\uC911\uD310\uC815\uC5D0 \uB9C8\uC774\uB108\uC2A4 \uC218\uC815\uC744
      \uC801\uC6A9\uD55C\uB2E4. \uBA85\uC911\uD310\uC815\uC774 \uC131\uACF5\uD558\uACE0,
      \uBAA9\uD45C\uAC00 \uD68C\uD53C\uD310\uC815\uC5D0 \uC2E4\uD328\uD558\uBA74
      \uBAA9\uD45C\uC5D0\uAC8C 1d6 + \uC790\uC2E0\uC758 \uC18D\uB3C4 \uB9CC\uD07C\uC758
      \uB370\uBBF8\uC9C0\uB97C \uC785\uD78C\uB2E4."
    library: "\uC778\uC138\uC778  1"
    acquireMode: 0
    maxAcquireCount: 1
    statEffect:
      lifeBonus: 0
      sanityBonus: 0
      specialtyBonus: 0
