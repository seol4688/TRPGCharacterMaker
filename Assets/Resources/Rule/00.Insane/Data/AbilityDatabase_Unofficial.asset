  - name: "\uAD1C\uCC2E\uC544 \uC548\uC8FD\uC5B4"
    type: 1
    designatedSpecialtyType: 1
    designatedEntries:
    - isAreaEntry: 1
      value: "\uC9C0\uAC01"
    effect: "\uB2F9\uC2E0\uC774 \uCCB4\uB825\uC774 0\uC774 \uB420\uB9CC\uD07C\uC758
      \uB300\uBBF8\uC9C0\uB97C \uC785\uB294 \uC21C\uAC04 \uC0AC\uC6A9 \uAC00\uB2A5\uD558\uB2E4.
      \uC9C0\uC815\uD2B9\uAE30 \uD310\uC815\uC5D0 \uC131\uACF5\uD558\uBA74 \uB2F9\uC2E0\uC774
      \uC785\uC744 \uB300\uBBF8\uC9C0\uB97C \uC808\uBC18(\uC18C\uC218\uC810 \uBC84\uB9BC)\uC73C\uB85C
      \uB9CC\uB4E4 \uC218 \uC788\uB2E4. \uC774 \uC5B4\uBE4C\uB9AC\uD2F0\uB294 \uC138\uC158
      \uC911 1\uD68C\uB9CC \uC0AC\uC6A9 \uAC00\uB2A5\uD558\uB2E4."
    library: "\uC6D0\uB798\uB3C4 \uBB34\uC11C\uC6B4 \uD604\uB300 \uD55C\uAD6D"
    acquireMode: 0
    maxAcquireCount: 1
