  - name: "\uC65C \uB108\uB9CC?"
    type: 1
    designatedSpecialtyType: 0
    designatedEntries:
    - isAreaEntry: 0
      value: "\uB178\uC5EC\uC6C0"
    effect: "PC\uAC00 \uC0DD\uBA85\uB825 \uB610\uB294 \uC774\uC131\uB825\uC744 \uD68C\uBCF5\uD560
      \uB54C \uC0AC\uC6A9\uD560 \uC218 \uC788\uB2E4. \uD310\uC815\uC5D0 \uC131\uACF5\uD558\uBA74
      \uB2F9\uC2E0\uB3C4 \uADF8\uB9CC\uD07C \uD68C\uBCF5\uD560 \uC218 \uC788\uB2E4.
      (\uC804\uD22C\uC2DC\uC5D4 1\uD68C\uB9CC \uC0AC\uC6A9 \uAC00\uB2A5\uD558\uB2E4.)"
