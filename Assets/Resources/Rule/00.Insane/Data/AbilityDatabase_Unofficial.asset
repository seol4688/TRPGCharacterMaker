    - isAreaEntry: 0
      value: "\uD611\uBC15"
    effect: "\uC9C0\uC815\uD2B9\uAE30 \uD310\uC815\uC5D0 \uC131\uACF5\uD558\uACE0
      \uC0C1\uB300\uAC00 \uD68C\uD53C\uD310\uC815\uC5D0 \uC2E4\uD328\uD560 \uC2DC
      1D6-2\uC810\uC758 \uB300\uBBF8\uC9C0\uB97C \uC8FC\uACE0 \u3010\uC774\uC131\uCE58\u3011\uB97C
      1\uC810 \uAC10\uC18C\uC2DC\uD0A8\uB2E4."
    library: "\uC6D0\uB798\uB3C4 \uBB34\uC11C\uC6B4 \uD604\uB300 \uD55C\uAD6D"
    acquireMode: 0
    maxAcquireCount: 1
    statEffect:
      lifeBonus: 0
      sanityBonus: 0
      specialtyBonus: 0
  - name: "\uAE40\uCE58 \uC2F8\uB300\uAE30"
    type: 0
    designatedSpecialtyType: 0
    designatedEntries:
    - isAreaEntry: 0
      value: "\uB9DB"
    effect: "\uBA85\uC911\uD310\uC815\uC5D0 \uC131\uACF5\uD558\uACE0 \uD68C\uD53C\uD310\uC815\uC5D0
      \uC2E4\uD328\uD560 \uACBD\uC6B0 \uC0C1\uB300\uC5D0\uAC8C 1D6\uC810\uC758 \uB300\uBBF8\uC9C0\uB97C
      \uC8FC\uACE0, \uB300\uC0C1\uC740 \uB208\uC774 \uB530\uAC00\uC6CC\uC838 \uBC18\uB4DC\uC2DC
      \uC9C4\uD1B5\uC81C\uB97C \uC18C\uBE44\uD574\uC57C \uD55C\uB2E4. \uC18C\uBE44\uD560
      \uC9C4\uD1B5\uC81C\uAC00 \uC5C6\uC744 \uACBD\uC6B0\uC5D0 1\uB300\uBBF8\uC9C0\uB97C
      \uCD94\uAC00\uB85C \uBC1B\uB294\uB2E4."
    library: "\uC6D0\uB798\uB3C4 \uBB34\uC11C\uC6B4 \uD604\uB300 \uD55C\uAD6D"
    acquireMode: 0
    maxAcquireCount: 1
    statEffect:
      lifeBonus: 0
      sanityBonus: 0
      specialtyBonus: 0
  - name: "\uADF8\uB7F0\uAC8C \uC5B4\uB528\uC5B4"
    type: 1
    designatedSpecialtyType: 1
    designatedEntries:
    - isAreaEntry: 1
      value: "\uC815\uC11C"
    effect: "\uB2F9\uC2E0\uC774 \uACF5\uD3EC\uD310\uC815\uC744 \uD560 \uB54C, \uC9C0\uC815\uD2B9\uAE30
      \uD310\uC815\uC5D0 \uC131\uACF5\uD558\uBA74 \uACF5\uD3EC\uD310\uC815\uC5D0
      \uC790\uB3D9 \uC131\uACF5\uD55C\uB2E4."
    library: "\uC6D0\uB798\uB3C4 \uBB34\uC11C\uC6B4 \uD604\uB300 \uD55C\uAD6D"
    acquireMode: 0
    maxAcquireCount: 1
    statEffect:
      lifeBonus: 0
      sanityBonus: 0
      specialtyBonus: 0
  - name: "\uC6B0\uB9AC\uAC00 \uB0A8\uC774\uAC00"
    type: 1
    designatedSpecialtyType: 1
    designatedEntries:
    - isAreaEntry: 1
      value: "\uC815\uC11C"
    effect: "\uB2F9\uC2E0\uC774 \uD68C\uD53C\uD310\uC815\uC5D0\uC11C \uC2E4\uD328\uD588\uC744
      \uB54C \uC0AC\uC6A9\uD560 \uC218 \uC788\uB2E4. \uC9C0\uC815\uD2B9\uAE30 \uD310\uC815\uC5D0
      \uC131\uACF5\uD558\uBA74 \uAC19\uC740 \uD50C\uB86F\uC5D0 \uC788\uB294 \uCE90\uB9AD\uD130\uB4E4\uACFC
      \uB300\uBBF8\uC9C0\uB97C \uD3C9\uB4F1\uD558\uAC8C \uB098\uB204\uC5B4 \uBC1B\uB294\uB2E4.
      \uB098\uB204\uC5B4 \uB5A8\uC5B4\uC9C0\uC9C0 \uC54A\uB294 \uACBD\uC6B0 \uC5B4\uBE4C\uB9AC\uD2F0\uC758
      \uC0AC\uC6A9\uC790\uAC00 \uB354 \uB9CE\uC740 \uB300\uBBF8\uC9C0\uB97C \uBC1B\uB294\uB2E4."
    library: "\uC6D0\uB798\uB3C4 \uBB34\uC11C\uC6B4 \uD604\uB300 \uD55C\uAD6D"
    acquireMode: 0
    maxAcquireCount: 1
    statEffect:
      lifeBonus: 0
      sanityBonus: 0
      specialtyBonus: 0
  - name: "\uC218\uD5D8\uC0DD"
    type: 1
    designatedSpecialtyType: 0
    designatedEntries:
    - isAreaEntry: 0
      value: "\uAC71\uC815"
    effect: "\uB2F9\uC2E0\uC774 \uB3C4\uC8FC\uD310\uC815\uC5D0 \uC2E4\uD328\uD588\uC744
      \uB54C \uC0AC\uC6A9\uD560 \uC218 \uC788\uB2E4. \uC774 \uC5B4\uBE4C\uB9AC\uD2F0\uC758
      \uC9C0\uC815\uD2B9\uAE30\uB85C \uD55C \uBC88 \uB354 \uD310\uC815\uD574 \uC131\uACF5\uD588\uC744
      \uACBD\uC6B0 \uC790\uBC1C\uC801\uC778 \uD0C8\uB77D\uC5D0 \uC131\uACF5\uD55C\uB2E4."
