  - name: "\uC624\uD30C\uCE20"
    type: 2
    designatedSpecialtyType: 3
    designatedEntries: []
    effect: "\uC790\uC2E0\uC774 \uC785\uD790 \uC218 \uC788\uB294 \uB370\uBBF8\uC9C0\uAC00
      2\uC810 \uC99D\uAC00\uD55C\uB2E4. \uB610, \uC774 \uC774\uC2DD\uC740 \uBB34\uAE30
