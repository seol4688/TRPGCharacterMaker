    specialEffect: 0
  - name: "\uC7AC\uC561\uC758 \uB0A0"
    type: 0
    designatedSpecialtyType: 0
    designatedEntries:
    - isAreaEntry: 0
      value: "\uC885\uB9D0"
    effect: "\uBAA9\uD45C 1\uBA85\uC744 \uC120\uD0DD\uD558\uC5EC \uBA85\uC911\uD310\uC815\uC744
      \uD55C\uB2E4. \uBA85\uC911\uD310\uC815\uC774 \uC131\uACF5\uD558\uACE0 \uBAA9\uD45C\uAC00
      \uD68C\uD53C\uD310\uC815\uC5D0 \uC2E4\uD328\uD558\uBA74, \uBAA9\uD45C\uC5D0\uAC8C
      2D6+^\uC810\uC758 \uB370\uBBF8\uC9C0\uB97C \uC785\uD78C\uB2E4. \uC774 \uD6A8\uACFC\uB294
      \uD55C \uC804\uD22C\uB2F9 1\uD68C\uBC16\uC5D0 \uC0AC\uC6A9\uD560 \uC218 \uC5C6\uB2E4."
