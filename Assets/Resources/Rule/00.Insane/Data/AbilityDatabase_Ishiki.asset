  - name: "\uC2E0\uC758 \uC774\uCE58"
    type: 1
    designatedSpecialtyType: 3
    designatedEntries: []
    effect: "\uB2F9\uC2E0\uC774 \uC790\uC2E0\uC758 \u3010\uC774\uC131\uCE58\u3011\uB97C
      \uC18C\uBE44, \uAC10\uC18C \uC2DC\uD0A4\uB294 \uC5B4\uBE4C\uB9AC\uD2F0\uC758
      \uD6A8\uACFC\uB97C \uC0AC\uC6A9\uD588\uC744 \uB54C \uC0AC\uC6A9\uD560 \uC218
      \uC788\uB2E4. \uB2F9\uC2E0\uC758 \u3010\uC774\uC131\uCE58\u3011\uAC00 2\uC810
      \uC774\uD558\uB77C\uBA74 \uADF8 \u3010\uC774\uC131\uCE58\u3011\uC758 \uC18C\uBE44
      \uBC0F \uAC10\uC18C\uB97C \uBB34\uD6A8\uB85C \uD560 \uC218 \uC788\uB2E4."
    library: "\uC774\uC2DD"
    acquireMode: 0
    maxAcquireCount: 1
    statEffect:
      lifeBonus: 0
      sanityBonus: 0
      specialtyBonus: 0
    acquireCondition: "\uB2F9\uC2E0\uC774 \uCC29\uB780\uC0C1\uD0DC\uAC00 \uB410\uB2E4."
    specialEffect: 0
  - name: "\uAD34\uB85C\uC6B4 \uAE30\uC5B5"
    type: 1
    designatedSpecialtyType: 3
    designatedEntries: []
    effect: "\uB2F9\uC2E0\uC774 \uC7AC\uB3C4\uC804\uC744 \uD560 \uB54C \uC0AC\uC6A9\uD560
      \uC218 \uC788\uB2E4. \uADF8 \uC7AC\uB3C4\uC804 \uD310\uC815\uC5D0 +1\uC758
      \uC218\uC815\uC744 \uC801\uC6A9\uD55C\uB2E4."
