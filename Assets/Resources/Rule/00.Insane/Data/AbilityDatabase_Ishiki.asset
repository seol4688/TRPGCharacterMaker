    library: "\uC774\uC2DD"
    acquireMode: 0
    maxAcquireCount: 1
    statEffect:
      lifeBonus: 0
      sanityBonus: 0
      specialtyBonus: 0
    acquireCondition: "\uB2F9\uC2E0\uC758 \uC18C\uC911\uD55C \uC0AC\uB78C\uC774 \uC0AC\uB9DD\uD588\uB2E4."
    specialEffect: 0
  - name: "\uC131\uAC00"
    type: 0
    designatedSpecialtyType: 0
    designatedEntries:
    - isAreaEntry: 0
      value: "\uCE5C\uC560"
    effect: "\uAD34\uC774 \uC5D0\uB108\uBBF8 \uC911\uC5D0\uC11C \uC6D0\uD558\uB294
      \uB9CC\uD07C \uBAA9\uD45C\uB97C \uC120\uD0DD\uD558\uACE0 \uBA85\uC911\uD310\uC815\uC744
      \uD55C\uB2E4. \uBA85\uC911\uD310\uC815\uC774 \uC131\uACF5\uD558\uBA74, \uBAA9\uD45C\uB294
      \uAC01\uC790 \uD68C\uD53C\uD310\uC815\uC744 \uD55C\uB2E4. \uD68C\uD53C\uD310\uC815\uC5D0
      \uC2E4\uD328\uD55C \uBAA9\uD45C\uC5D0\uAC8C 3\uC810\uC758 \uB370\uBBF8\uC9C0\uB97C
      \uC785\uD78C\uB2E4."
    library: "\uC774\uC2DD"
    acquireMode: 0
    maxAcquireCount: 1
    statEffect:
      lifeBonus: 0
      sanityBonus: 0
      specialtyBonus: 0
